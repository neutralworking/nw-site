---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Contact">
  <section class="container-narrow pt-20 pb-24">
    <h1 class="text-2xl sm:text-3xl font-semibold tracking-tight text-ink">Get in touch</h1>
    <p class="mt-4 text-base text-ink-muted max-w-md">
      Book a free 30-minute discovery call. No pitch deck, no proposal until we've talked.
    </p>
    <p class="mt-8 text-sm text-ink-muted">Booking link coming soon.</p>
  </section>
</BaseLayout>
