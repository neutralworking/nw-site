---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import CaseStudy from '../../components/CaseStudy.astro';

const entries = await getCollection('cases');
const work = entries
  .sort((a, b) => a.data.order - b.data.order)
  .map(e => ({
    title: e.data.title,
    summary: e.data.summary,
    tags: e.data.tags,
    href: `/work/${e.id}`,
  }));
---

<BaseLayout title="Work" description="Selected case studies from product and delivery engagements.">
  <section class="container-default pt-20 pb-16">
    <h1 class="text-2xl sm:text-3xl font-semibold tracking-tight text-ink">Work</h1>
    <p class="mt-4 text-lg text-ink-muted max-w-xl">Selected case studies.</p>
  </section>
  <section class="border-t border-border">
    <div class="container-default py-12">
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        {work.map(w => <CaseStudy {...w} />)}
      </div>
    </div>
  </section>
</BaseLayout>
