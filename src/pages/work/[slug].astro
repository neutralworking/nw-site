---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Pill from '../../components/Pill.astro';
import CTA from '../../components/CTA.astro';
import ServiceCard from '../../components/ServiceCard.astro';

export async function getStaticPaths() {
  const entries = await getCollection('cases');
  return entries.map(entry => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const { data: d } = entry;

const allServices = await getCollection('services');
const related = allServices
  .filter(s => d.related_services.includes(s.id))
  .sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout title={d.title} description={d.headline}>

  <!-- Header -->
  <section class="container-narrow pt-16 pb-10">
    <a href="/work" class="text-sm text-ink-muted hover:text-ink transition-colors">← Work</a>
    <h1 class="mt-6 text-2xl sm:text-3xl font-semibold tracking-tight text-ink">{d.title}</h1>
    <p class="mt-3 text-lg text-ink-muted">{d.headline}</p>
  </section>

  <!-- Context -->
  <section class="border-t border-border bg-surface">
    <div class="container-narrow py-10">
      <h2 class="text-sm font-medium text-ink-muted uppercase tracking-wider mb-4">Context</h2>
      <p class="text-sm text-ink leading-relaxed">{d.context}</p>
    </div>
  </section>

  <!-- The problem -->
  <section class="border-t border-border">
    <div class="container-narrow py-10">
      <h2 class="text-sm font-medium text-ink-muted uppercase tracking-wider mb-4">The problem</h2>
      <p class="text-sm text-ink leading-relaxed">{d.problem}</p>
    </div>
  </section>

  <!-- What I did -->
  <section class="border-t border-border bg-surface">
    <div class="container-narrow py-10">
      <h2 class="text-sm font-medium text-ink-muted uppercase tracking-wider mb-4">What I did</h2>
      <ul class="space-y-3">
        {d.what_i_did.map(item => (
          <li class="text-sm text-ink leading-relaxed flex gap-2">
            <span class="text-accent mt-0.5 shrink-0">→</span>
            <span>{item}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- Outcome -->
  <section class="border-t border-border">
    <div class="container-narrow py-10">
      <h2 class="text-sm font-medium text-ink-muted uppercase tracking-wider mb-4">Outcome</h2>
      <ul class="space-y-3">
        {d.outcome.map(item => (
          <li class="text-sm text-ink leading-relaxed flex gap-2">
            <span class="text-accent mt-0.5 shrink-0">✓</span>
            <span>{item}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- What was used -->
  <section class="border-t border-border bg-surface">
    <div class="container-narrow py-10">
      <h2 class="text-sm font-medium text-ink-muted uppercase tracking-wider mb-4">What was used</h2>
      <div class="flex flex-wrap gap-2">
        {d.tools.map(tool => <Pill label={tool} />)}
      </div>
    </div>
  </section>

  <!-- Related services -->
  {related.length > 0 && (
    <section class="border-t border-border">
      <div class="container-narrow py-10">
        <h2 class="text-sm font-medium text-ink-muted uppercase tracking-wider mb-6">Related services</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          {related.map(s => (
            <ServiceCard
              name={s.data.title}
              description={s.data.tagline}
              price={s.data.price_from}
              href={`/services/${s.id}`}
            />
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- CTA -->
  <section class="border-t border-border bg-surface">
    <div class="container-narrow py-16 text-center">
      <h2 class="text-xl font-semibold text-ink mb-3">Interested in working together?</h2>
      <p class="text-base text-ink-muted mb-8 max-w-md mx-auto">
        Book a free 30-minute discovery call. No pitch deck, no proposal until we've talked.
      </p>
      <CTA label="Book a discovery call" href="/contact" />
    </div>
  </section>

</BaseLayout>
